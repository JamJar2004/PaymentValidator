<Window x:Class="PaymentValidator.Views.RemoveBlacklistedUsersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PaymentValidator.Views" 
		xmlns:viewmodels="clr-namespace:PaymentValidator.ViewModels"
		mc:Ignorable="d"
		WindowStartupLocation="CenterScreen"
		Title="Uncheck users to remove from blacklist" 
		Height="400" 
		Width="400" 
		d:DataContext="{d:DesignInstance {x:Type viewmodels:RemoveBlacklistedUsersViewModel}}">
    <Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="auto"/>
		</Grid.RowDefinitions>
		
		<ItemsControl Grid.Row="0" Margin="5, 5, 5, 2.5" ItemsSource="{Binding Users}">
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<CheckBox Margin="5" IsChecked="{Binding IsBlacklisted}" Content="{Binding Name}"/>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<Grid Grid.Row="1" Height="40">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<Button Grid.Column="0" Margin="5, 2.5, 2.5, 5" Content="OK" Command="{Binding OkCommand}" 
					CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"/>
			
			<Button Grid.Column="1" Margin="2.5, 2.5, 5, 5" Content="Cancel" IsCancel="True"/>
		</Grid>
    </Grid>
</Window>
